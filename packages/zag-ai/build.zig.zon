.{
    .name = .zag_ai,
    .version = "0.1.0",
    .fingerprint = 0x36b0f4d4a1d0538d,
    .minimum_zig_version = "0.16.0",
    .dependencies = .{
        .openai_zig = .{
            .path = "../openai-zig",
        },
        .zag_types = .{
            .path = "../zag-types",
        },
        .curl = .{
            // jiacai2050/zig-curl v0.5.0 — seed local cache if zig fetch fails:
            //   curl -fsSL -o /tmp/zig-curl-0.5.0.tar.gz <url>
            //   zig fetch file:///tmp/zig-curl-0.5.0.tar.gz
            .url = "https://github.com/jiacai2050/zig-curl/archive/refs/tags/v0.5.0.tar.gz",
            .hash = "curl-0.5.0-P4tT4e_-AABZBa1zBmiSKFQo7xV0DJ2cUxFfH4KiQKj2",
            .lazy = true,
        },
        .comptime_serde = .{
            // Library-only mirror of jiacai2050/comptime-serde v0.2.0 (no zigcli).
            .path = "../comptime-serde",
        },
    },
    .paths = .{
        "build.zig",
        "build.zig.zon",
        "src",
        "data",
        "README.md",
    },
}
